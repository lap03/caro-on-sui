# Copy to .env.local (or .env) and fill in your values.
# All NEXT_PUBLIC_* vars are exposed to the browser. Server-only keys (bottom) are not.

NEXT_PUBLIC_SUI_NETWORK=testnet
NEXT_PUBLIC_ENOKI_API_KEY=your_enoki_public_api_key_here
NEXT_PUBLIC_GOOGLE_CLIENT_ID=your_google_client_id_here
NEXT_PUBLIC_PACKAGE_ID=0x99b99091098aac585ebf029b627dea6a105d91b26bdda7aac7ec7579b5e94d3e
# Original package id (first publish). Move type tags and event types always use
# this — after `sui client upgrade`, NEXT_PUBLIC_PACKAGE_ID points at the new bytecode,
# but event types and struct tags stay rooted at the original id.
NEXT_PUBLIC_ORIGINAL_PACKAGE_ID=0x99b99091098aac585ebf029b627dea6a105d91b26bdda7aac7ec7579b5e94d3e
NEXT_PUBLIC_LEADERBOARD_ID=0xb747e723709decb85dd90c5e2d1ca9920ebc40b49d3c5f9b73b76ae8995bf442
NEXT_PUBLIC_WALRUS_PUBLISHER=https://publisher.walrus-testnet.walrus.space
NEXT_PUBLIC_WALRUS_AGGREGATOR=https://aggregator.walrus-testnet.walrus.space
NEXT_PUBLIC_SEAL_PACKAGE_ID=0x0
NEXT_PUBLIC_SEAL_SERVER_OBJECT_ID=0xb012378c9f3799fb5b1a7083da74a4069e3c3f1c93de0b27212a5799ce1e1e98
NEXT_PUBLIC_SEAL_AGGREGATOR_URL=https://seal-aggregator-testnet.mystenlabs.com
NEXT_PUBLIC_SEAL_ENABLED=false

# Server-only (used by app/api routes). Do NOT prefix with NEXT_PUBLIC_.
ENOKI_SECRET_KEY=your_enoki_private_key_here
# Comma-separated if you want to support multiple package ids (upgrade path).
PACKAGE_ID=0x_your_package_id_here
